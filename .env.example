# ==========================================
# Distributed Job Scheduler Environment Variables
# ==========================================

# 1. Server Configuration
PORT=4000
NODE_ENV=development

# 2. Database Connection (PostgreSQL)
# For docker-compose, this is postgresql://postgres:postgres@postgres:5432/scheduler_db?schema=public
# For local run without docker, this is postgresql://postgres:postgres@localhost:5432/scheduler_db?schema=public
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/scheduler_db?schema=public"

# 3. Redis Queue Connection
# For docker-compose, this is redis
# For local run without docker, this is localhost
REDIS_HOST=localhost
REDIS_PORT=6379

# 4. Security & JWT Secrets
JWT_SECRET=super-secret-jwt-key-change-in-production
JWT_REFRESH_SECRET=super-secret-refresh-key-change-in-production

# 5. Frontend UI URL
FRONTEND_URL=http://localhost:5173

# 6. Worker configuration
WORKER_CONCURRENCY=5
